{
    "clickhouse": {
        "host": "127.0.0.1",
        "port": 8123,
        "user": "default",
        "password": "",
        "database": "turbine_monitor",
        "timeout_ms": 5000,
        "batch_size": 1000,
        "flush_interval_ms": 1000
    },
    "udp": {
        "host": "0.0.0.0",
        "port": 9000,
        "receive_buffer_size": 1048576,
        "processing_threads": 8,
        "queue_max_size": 100000
    },
    "api": {
        "host": "0.0.0.0",
        "port": 8080,
        "enable_cors": true,
        "cors_origin": "*",
        "thread_pool_size": 4
    },
    "iec61850": {
        "enable_push": true,
        "gateway_host": "192.168.1.100",
        "gateway_port": 102,
        "ied_name": "TURBINE_MONITOR",
        "report_interval_ms": 1000
    },
    "thresholds": {
        "cavitation_incipient": 0.3,
        "cavitation_critical": 0.6,
        "cavitation_developed": 0.8,
        "vibration_warning": 0.3,
        "vibration_alarm": 0.5,
        "vibration_critical": 0.8,
        "life_warning_percent": 10.0,
        "life_alarm_percent": 5.0
    },
    "processing": {
        "fft_window_size": 1024,
        "fft_overlap": 0.5,
        "wavelet_levels": 5,
        "wavelet_type": "db4",
        "cavitation_detection_interval_ms": 100,
        "life_assessment_interval_ms": 1000,
        "alarm_cooldown_ms": 30000
    },
    "models": {
        "isolation_forest": {
            "num_trees": 100,
            "subsample_size": 256,
            "contamination": 0.1
        },
        "autoencoder": {
            "input_dim": 32,
            "hidden_dim": 16,
            "latent_dim": 8,
            "threshold": 0.05
        },
        "ensemble_weights": {
            "isolation_forest": 0.5,
            "autoencoder": 0.5
        }
    },
    "material": {
        "name": "13Cr4Ni_stainless_steel",
        "fatigue_strength_coefficient_k": 5e-12,
        "fatigue_strength_exponent_m": 3.0,
        "ultimate_tensile_strength_mpa": 750.0,
        "yield_strength_mpa": 550.0,
        "youngs_modulus_gpa": 200.0,
        "poissons_ratio": 0.3
    },
    "mpc_control": {
        "enabled": true,
        "default_mode": 3,
        "prediction_horizon": 20,
        "control_horizon": 5,
        "sample_time_s": 0.1,
        "weight_efficiency": 1.0,
        "weight_cavitation_risk": 3.0,
        "weight_power_tracking": 2.0,
        "weight_control_rate": 0.5,
        "guide_vane_min_deg": 15.0,
        "guide_vane_max_deg": 85.0,
        "guide_vane_rate_limit_dps": 5.0,
        "power_min_mw": 100.0,
        "power_max_mw": 750.0,
        "power_rate_limit_mwps": 20.0,
        "cavitation_safe_threshold": 0.4,
        "cavitation_emergency_threshold": 0.75,
        "mpc_max_iterations": 50,
        "mpc_tolerance": 0.0001
    },
    "robot_planner": {
        "enabled": true,
        "auto_trigger_life_pct": 10.0,
        "damage_threshold_mm2": 50.0,
        "robot_speed_mm_s": 50.0,
        "weld_speed_mm_s": 8.0,
        "polish_speed_mm_s": 20.0,
        "weld_bead_width_mm": 6.0,
        "polish_step_mm": 0.5,
        "inspection_grid_step_mm": 10.0,
        "path_waypoint_count": 64,
        "turbine_inner_radius_mm": 2500.0,
        "turbine_outer_radius_mm": 5000.0,
        "safety_clearance_mm": 50.0,
        "default_repair_mode": 3
    },
    "unit_scheduler": {
        "enabled": true,
        "scheduling_interval_s": 300,
        "horizon_steps": 24,
        "time_step_s": 3600,
        "weight_efficiency": 2.0,
        "weight_cavitation_penalty": 5.0,
        "weight_startup_cost": 1.0,
        "min_up_time_s": 14400,
        "min_down_time_s": 7200,
        "max_cavitation_allow": 0.5,
        "reserve_margin_pct": 5.0,
        "ramp_rate_limit_mwps": 10.0,
        "mip_max_threads": 4,
        "mip_time_limit_ms": 5000,
        "mip_gap_tolerance": 0.001
    },
    "acoustic_diagnosis": {
        "enabled": true,
        "embedding_dim": 32,
        "max_patterns_per_type": 100,
        "update_interval_s": 60,
        "similarity_threshold": 0.75,
        "novelty_threshold": 0.15,
        "triplet_margin": 0.3,
        "max_clusters": 10,
        "kmeans_max_iter": 300,
        "cluster_merge_threshold": 0.5,
        "min_samples_per_cluster": 5,
        "pattern_library_path": "config/models/acoustic_patterns.json"
    },
    "logging": {
        "level": "info",
        "file_path": "/var/log/turbine_monitor",
        "max_file_size_mb": 100,
        "max_files": 10
    }
}
